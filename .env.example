# PostgreSQL connection string
# For local development (without Docker): spin up a local Postgres instance
# and update the credentials below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghanajerseystore

# NextAuth secret – generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Public URL of the app (used in password reset links)
NEXTAUTH_URL=http://localhost:3000

# The email address and password for the built-in admin account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password-here

# Optional: Email settings for password reset emails
# EMAIL_SERVER=smtp://username:password@smtp.example.com:587
# EMAIL_FROM=noreply@adumpzkanta.store

# Role-based access control notes:
# - admin: full access (products, orders, user management) – set via ADMIN_EMAIL/ADMIN_PASSWORD above
# - manager: order management only – promote a registered user to manager via the Admin → Users tab
# - user: default role for all registered users (can place orders, view their own orders)

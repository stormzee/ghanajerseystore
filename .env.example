# PostgreSQL connection string
# For local development (without Docker): spin up a local Postgres instance
# and update the credentials below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghanajerseystore

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth secret – generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# The email address of the admin user (must match the Google account email)
ADMIN_EMAIL=admin@example.com

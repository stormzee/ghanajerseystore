# PostgreSQL connection string
# For local development (without Docker): spin up a local Postgres instance
# and update the credentials below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghanajerseystore

# NextAuth secret – generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# The email address of the admin user
ADMIN_EMAIL=admin@example.com

# The password for the admin user
ADMIN_PASSWORD=your-admin-password-here
